{
  "name": "@civic-os/schema-eval",
  "version": "0.1.0",
  "description": "Evaluation harness for LLM schema generation quality",
  "type": "module",
  "main": "dist/runner.js",
  "bin": {
    "civicos-eval": "dist/runner.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "eval": "node dist/runner.js",
    "db:up": "docker compose -f src/docker/docker-compose.eval.yml up -d",
    "db:down": "docker compose -f src/docker/docker-compose.eval.yml down -v",
    "db:reset": "npm run db:down && npm run db:up"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^13.1.0",
    "pg": "^8.13.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "AGPL-3.0-or-later"
}
