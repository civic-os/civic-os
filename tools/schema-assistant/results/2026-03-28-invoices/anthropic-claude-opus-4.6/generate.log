  client_id INTEGER NOT NULL,
  amount MONEY NOT NULL,
  invoice_date DATE NOT NULL DEFAULT CURRENT_DATE,
  status_id INT NOT NULL DEFAULT get_initial_status('invoice'),
  notes TEXT
);

