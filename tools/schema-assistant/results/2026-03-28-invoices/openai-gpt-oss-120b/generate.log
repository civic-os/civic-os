── [DDL] Table creation ──
CREATE TABLE public.invoices (
  id           BIGINT GENERATED BY DEFAULT AS IDENTITY NOT NULL,
  created_at   TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at   TIMESTAMPTZ,
  display_name TEXT NOT NULL,                     -- e.g. “INV‑2025‑001”
  client_id    INT NOT NULL,
  amount       MONEY NOT NULL,
  invoice_date DATE NOT NULL,
  status       INT NOT NULL DEFAULT get_initial_status('invoice'),
  notes        TEXT,
  -- audit
  created_by   UUID DEFAULT current_user_id()
);

-- Primary key
ALTER TABLE public.invoices
  ADD CONSTRAINT invoices_pkey PRIMARY KEY (id);

-- Foreign keys (deferred validation)
ALTER TABLE public.invoices
  ADD CONSTRAINT invoices_client_id_fkey
    FOREIGN KEY (client_id) REFERENCES public.clients(id) NOT VALID;
ALTER TABLE public.invoices VALIDATE CONSTRAINT invoices_client_id_fkey;

ALTER TABLE public.invoices
  ADD CONSTRAINT invoices_status_fkey
    FOREIGN KEY (status) REFERENCES metadata.statuses(id) NOT VALID;
ALTER TABLE public.invoices VALIDATE CONSTRAINT invoices_status_fkey;

ALTER TABLE public.invoices
  ADD CONSTRAINT invoices_created_by_fkey
    FOREIGN KEY (created_by) REFERENCES metadata.civic_os_users(id) NOT VALID;
ALTER TABLE public.invoices VALIDATE CONSTRAINT invoices_created_by_fkey;

